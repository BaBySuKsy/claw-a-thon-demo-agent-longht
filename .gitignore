# Local knowledge cache — large external dumps (GitLab DAGs, Confluence, Jira).
# Regenerated by the ingestion pipeline and baked into the Docker image at build
# time (NOT excluded by .dockerignore). Kept out of git to keep the repo reviewable.
src/data_platform/cache/

# Ingestion-derived knowledge artifacts that contain INTERNAL infra details
# (host IPs, DB users, internal hostnames, employee emails). Generated by the
# ingestion pipeline and baked into the Docker image — NEVER committed to the
# public repo. See README "Data & ingestion".
src/data_platform/confluence_knowledge.json
src/data_platform/confluence_index.json
src/data_platform/file_descriptions.json

# Temporal observation log (Graphiti-style) — accumulates live freshness/schema
# observations at runtime; references internal table URNs. Runtime artifact, not source.
src/data_platform/history/

# Internal repo analysis artifacts (internal code structure/paths) — not for public repo
src/data_platform/temp_analysis/
# Scratch test scripts (internal hostnames/project codes)
test_jira.py

# demo video (large, shows real names) — never publish
*.mp4
docs/*.mp4
.env.deploy
