# Secrets & credentials — never in image
.greennode.json
.env
.env.*
credentials.json
.agentbase-state.json
.agentbase/

# Version control & IDE
.git
.gitignore
.idea
.vscode

# Python artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.pytest_cache
.mypy_cache

# Dev-only — not needed at runtime
venv/
agentbase-skills/
docx/
docs/
test_*.py
GEMINI.md
/*.md

# Raw ingestion dumps — never bake. NOTE: cache/, confluence_index.json and history/
# ARE baked on purpose now — they hold the fully-synthetic dataset the agent's tools
# serve (generated by scripts/generate_synthetic_data.py). Only these stay excluded:
src/data_platform/file_descriptions.json
temp_analysis/
*.mp4
