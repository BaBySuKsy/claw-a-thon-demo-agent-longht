# ── LLM (GreenNode MaaS, OpenAI-compatible) ──────────────────────────────────
LLM_MODEL=minimax/minimax-m2.5
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=your_maas_api_key_here

# Alternative models (optional)
# LLM_MODEL_FREE=...
# LLM_MODEL_GOOGLE=...

# ── DataHub (schema, lineage, freshness) ─────────────────────────────────────
DATAHUB_BASE_URL=https://your-datahub-host.internal
DATAHUB_USERNAME=your_datahub_username
DATAHUB_PASSWORD=your_datahub_password

# ── GitLab (DAG code, recent commits) ────────────────────────────────────────
GITLAB_BASE_URL=https://your-gitlab-host.internal
GITLAB_USER=your_gitlab_user
GITLAB_TOKEN=your_gitlab_personal_access_token

# ── Confluence (documentation) ───────────────────────────────────────────────
CONFLUENCE_URL=https://your-confluence-host.internal
CONFLUENCE_USER=your_confluence_user
CONFLUENCE_API_TOKEN=your_confluence_token

# ── Jira (tickets, incidents) ────────────────────────────────────────────────
JIRA_URL=https://your-jira-host.internal
JIRA_USER=your_jira_user
JIRA_TOKEN=your_jira_personal_access_token

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=8080
